<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>System UI</title>
    <style>
        :root { --red: #ff0000; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; user-select: none; margin: 0; padding: 0; }
        body { background: transparent; font-family: sans-serif; height: 100vh; overflow: hidden; }

        /* TELA DE LOGIN APARECE NA HORA */
        #loginScreen { 
            position: fixed; inset: 0; background: #000; 
            display: flex; flex-direction: column; justify-content: center; align-items: center; 
            z-index: 10000;
        }

        input[type="password"] { 
            padding: 15px; width: 75%; background: #0a0a0a; border: 1px solid var(--red); 
            color: #fff; text-align: center; border-radius: 8px; margin-bottom: 20px; font-size: 16px;
        }

        .btn-login { 
            background: var(--red); color: white; border: none; padding: 15px 50px; 
            border-radius: 8px; font-weight: bold; cursor: pointer;
        }

        /* MENU QUE FICA ESCONDIDO ATÉ LOGAR */
        #mainMenu {
            display: none; width: 280px; background: #000; border: 2px solid var(--red);
            border-radius: 12px; position: absolute; left: 50%; top: 50%;
            transform: translate(-50%, -50%); z-index: 9999;
        }

        .float-icon {
            width: 45px; height: 45px; background: rgba(255,0,0,0.5);
            position: fixed; top: 20%; left: 10px; border-radius: 50%;
            display: none; z-index: 10001; border: 1px solid #fff;
        }
    </style>
</head>
<body>

<div id="loginScreen">
    <h2 style="color:white; margin-bottom: 20px;">SYSTEM <span style="color:red">LOGIN</span></h2>
    <input type="password" id="pass" placeholder="DIGITE A CHAVE">
    <button class="btn-login" onclick="entrar()">ENTRAR</button>
</div>

<div id="floatIcon" onclick="abrir()" class="float-icon"></div>

<div id="mainMenu">
    <div style="padding:15px; text-align:center; border-bottom:1px solid #222;">
        <h3 style="color:white; font-size:14px;">VITORZIN SUPREME</h3>
    </div>
    <div style="padding:20px;">
        <button onclick="alert('Ativado')" style="width:100%; padding:10px; background:#111; color:red; border:1px solid red; border-radius:5px;">ATIVAR ANTI-BAN</button>
        <button onclick="fechar()" style="width:100%; padding:10px; background:#222; color:white; border:none; border-radius:5px; margin-top:10px;">FECHAR</button>
    </div>
</div>

<script>
    function entrar() {
        const p = document.getElementById('pass').value;
        if(p === "1") {
            document.getElementById('loginScreen').style.display = 'none'; // Some o login
            document.getElementById('floatIcon').style.display = 'block'; // Aparece o botão do menu
            alert("SUCESSO!");
        } else {
            alert("SENHA ERRADA");
        }
    }

    function abrir() { document.getElementById('mainMenu').style.display = 'block'; }
    function fechar() { document.getElementById('mainMenu').style.display = 'none'; }
</script>
</body>
</html>
